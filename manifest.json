{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.1.0",
  "description": "__MSG_extDescription__",
  "default_locale": "ja",
  "minimum_chrome_version": "114",
  "permissions": ["activeTab", "scripting", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Re:Chrome Text",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "replace-all-shortcut": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "Alt+Shift+R",
        "windows": "Alt+Shift+R"
      },
      "description": "__MSG_commandReplaceAll__"
    }
  }
}
